OPENAI_BASE_URL=https://api-vip.codex-for.me/v1
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.4
OPENAI_USER_AGENT=Mozilla/5.0 (Macintosh; Intel Mac OS X 14_0) CodexTranslator/1.0
MEMAGENT_TRIAL_SESSION_LIMIT=5

# DeepSeek API（填写 DEEPSEEK_API_KEY 后可作为默认/试用 Key 使用）
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-chat

# Qwen / 通义千问 API（DashScope OpenAI-compatible）
QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
QWEN_API_KEY=
QWEN_MODEL=qwen-plus

# Kimi / Moonshot API
KIMI_BASE_URL=https://api.moonshot.cn/v1
KIMI_API_KEY=
KIMI_MODEL=moonshot-v1-8k

# 可选：外部图谱提取配置
GRAPH_LLM_PROVIDER=
GRAPH_LLM_BASE_URL=
GRAPH_LLM_API_KEY=
GRAPH_LLM_MODEL=
MEM0_LLM_BASE_URL=https://api.deepseek.com
MEM0_LLM_API_KEY=
MEM0_L3_LLM_BASE_URL=https://api.deepseek.com
MEM0_LLM_MODEL=deepseek-chat
MEM0_L3_LLM_API_KEY=
MEM0_L3_LLM_MODEL=deepseek-chat

MEMAGENT_ENABLE_MEM0_RUNTIME=1
MEMAGENT_DEBUG_RETRIEVAL=0
MEMAGENT_ENABLE_INTENT_RECOGNITION=0
MEMAGENT_RETRIEVAL_FOCUS_POLICY=input

# 记忆检索增强：向量召回 + BM25 召回 -> RRF 融合 -> 可选 Cross-Encoder 重排
MEM0_BM25_ENABLED=1
MEM0_RRF_ENABLED=1
MEM0_RRF_K=60
MEM0_RETRIEVAL_CANDIDATE_TOP_K=10
MEM0_BM25_POOL_LIMIT=200
# auto: 仅发现本地 models/bge-reranker-base 或显式配置模型时启用；1: 强制启用；0: 关闭
MEM0_RERANKER_ENABLED=0
MEM0_RERANKER_MODEL_PATH=
MEM0_RERANKER_MODEL=
MEM0_RERANKER_BATCH_SIZE=8
MEM0_RERANKER_MAX_LENGTH=512
MEMAGENT_BACKGROUND_MEMORY_WARMUP=1


